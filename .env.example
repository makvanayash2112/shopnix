# MongoDB
MONGODB_URI=mongodb://127.0.0.1:27017/shopnix_ondc

# Admin seed (npm run seed:admin / seed:products)
ADMIN_EMAIL=admin@shopnix.com
ADMIN_PASSWORD=Shopnix@Admin2026

# JWT
JWT_SECRET=change-this-to-a-long-random-secret
JWT_EXPIRES_IN=7d

# Local dev: leave empty for same-origin (port 3000). Vercel: leave unset.
# API_BASE_URL=http://localhost:3000
# NEXT_PUBLIC_API_URL=

# Vercel Blob (required for product images on Vercel)
BLOB_READ_WRITE_TOKEN=

# Express API port (npm run dev proxies :3000 → :4000)
API_PORT=4000

# ONDC Seller (BPP) — register on https://portal.ondc.org
# Subscriber ID must match portal exactly (e.g. shopnix-nine.vercel.app)
ONDC_BPP_ID=shopnix-nine.vercel.app
ONDC_BPP_URI=https://shopnix-nine.vercel.app/ondc
ONDC_SUBSCRIBER_ID=shopnix-nine.vercel.app
ONDC_UNIQUE_KEY_ID=843e59d7-0bcc-4be5-bc5c-aa8c4240beb5
# Private key must pair with portal signing public key (View Details in portal)
ONDC_SIGNING_PRIVATE_KEY=
# Optional: compare in logs (npm run ondc:keys shows public from private)
ONDC_SIGNING_PUBLIC_KEY=
ONDC_DOMAIN=ONDC:RET10
ONDC_CITY=std:080
ONDC_COUNTRY=IND
# Set false only for local debugging (never in production)
# ONDC_VERIFY_SIGNATURES=false
# Buyer BAP routes — leave unset for seller-only (default)
# ONDC_ENABLE_BAP=true
# ONDC_BAP_ID=
# ONDC_BAP_URI=https://shopnix-nine.vercel.app/ondc-bap

# Store / seller defaults
DEFAULT_STORE_NAME=Shopnix Store
DEFAULT_STORE_GSTIN=
DEFAULT_STORE_EMAIL=admin@shopnix.local

# MongoDB
MONGODB_URI=mongodb://127.0.0.1:27017/shopnix_ondc

# Admin seed (npm run seed:admin / seed:products)
ADMIN_EMAIL=admin@shopnix.com
ADMIN_PASSWORD=Shopnix@Admin2026

# JWT
JWT_SECRET=change-this-to-a-long-random-secret
JWT_EXPIRES_IN=7d

# Local dev: leave empty for same-origin (port 3000). Vercel: leave unset.
# API_BASE_URL=http://localhost:3000
# NEXT_PUBLIC_API_URL=

# Vercel Blob (required for product images on Vercel)
BLOB_READ_WRITE_TOKEN=

# Express API port (npm run dev proxies :3000 → :4000)
API_PORT=4000

# ONDC — register BOTH on https://portal.ondc.org (see docs/ONDC_REGISTRATION.md)
# Use HTTPS public URL in staging/prod (ngrok for local: ngrok http 4000)
ONDC_BPP_ID=shopnix-bpp.yourdomain.com
ONDC_BPP_URI=https://your-project.vercel.app/ondc
ONDC_BAP_ID=shopnix-bap.yourdomain.com
ONDC_BAP_URI=https://your-project.vercel.app/ondc-bap
ONDC_DOMAIN=ONDC:RET10
ONDC_CITY=std:080
ONDC_COUNTRY=IND
ONDC_SIGNING_PRIVATE_KEY=
ONDC_SUBSCRIBER_ID=

# Store / seller defaults
DEFAULT_STORE_NAME=Shopnix Store
DEFAULT_STORE_GSTIN=
DEFAULT_STORE_EMAIL=admin@shopnix.local

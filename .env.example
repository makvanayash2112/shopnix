# MongoDB
MONGODB_URI=mongodb://127.0.0.1:27017/shopnix_ondc

# Superadmin seed (npm run seed:superadmin)
SUPERADMIN_EMAIL=superadmin@shopnix.com
SUPERADMIN_PASSWORD=Shopnix@Admin2026
SUPERADMIN_NAME=Shopnix Superadmin

# JWT
JWT_SECRET=change-this-to-a-long-random-secret
JWT_EXPIRES_IN=7d

# Local dev: leave empty for same-origin (port 3000). Vercel: leave unset.
# API_BASE_URL=http://localhost:3000
# NEXT_PUBLIC_API_URL=

# Vercel Blob (required for persistent product image uploads on Vercel)
# On your own server, uploaded files are saved in public/uploads/products and DB stores filenames.
BLOB_READ_WRITE_TOKEN=
# Public site URL (product images + ONDC catalog). On Vercel, VERCEL_URL is used if unset.
API_BASE_URL=https://shopnix-nine.vercel.app

# Express API port (npm run dev proxies :3000 → :4000)
API_PORT=4000

# ONDC Seller (BPP) — register on https://portal.ondc.org
# Subscriber ID must match portal exactly (e.g. shopnix-nine.vercel.app)
ONDC_BPP_ID=shopnix-nine.vercel.app
ONDC_BPP_URI=https://shopnix-nine.vercel.app/ondc
ONDC_SUBSCRIBER_ID=shopnix-nine.vercel.app
ONDC_UNIQUE_KEY_ID=843e59d7-0bcc-4be5-bc5c-aa8c4240beb5
# Private key must pair with portal signing public key (View Details in portal)
ONDC_SIGNING_PRIVATE_KEY=
ONDC_SIGNING_PUBLIC_KEY=
ONDC_DOMAIN=ONDC:RET10
# Seller NP (Pramaan): single provider + SNP (default). Set true for multi-seller MSN catalog.
# ONDC_MSN_CATALOG=false
ONDC_CITY=std:080
ONDC_COUNTRY=IND
# Set false only for local debugging (never in production)
# ONDC_VERIFY_SIGNATURES=false
# On Vercel: auto-accept Pramaan/GCR search until registry v2 lookup works (default true on VERCEL)
# ONDC_PREPROD_TRUST_SEARCH=true
# Optional manual public keys if registry lookup fails:
# ONDC_TRUSTED_KEYS_JSON=[{"subscriberId":"preprod.gateway.proteantech.in","uniqueKeyId":"e4f95b8d-fb8a-4e38-b7f5-de3e21a0a28f","publicKey":"..."}]
# Marketplace display name for ONDC catalog metadata
DEFAULT_STORE_NAME=Shopnix Marketplace
